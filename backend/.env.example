# ═══════════════════════════════════════
# TON Casino — Production Environment
# ═══════════════════════════════════════

# Server
PORT=3000
NODE_ENV=production
REQUEST_TIMEOUT_MS=30000

# ─── MongoDB (Replica Set) ───
MONGODB_URI=mongodb://user:password@mongo1:27017,mongo2:27017,mongo3:27017/ton_casino?replicaSet=rs0&authSource=admin
MONGODB_POOL_SIZE=50
MONGODB_QUERY_TIMEOUT_MS=10000
# ─── Redis ───
# Single instance:
REDIS_URL=redis://:password@redis-host:6379
# Cluster mode (comma-separated, leave empty for single instance):
REDIS_CLUSTER_URLS=

# ─── Telegram Bot ───
BOT_TOKEN=your_bot_token_here

# ─── JWT ───
# Generate with: openssl rand -base64 64
JWT_SECRET=your_64_char_min_secret_here
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_TTL=2592000

# ─── TON Blockchain ───
ESCROW_CONTRACT_ADDRESS=your_escrow_contract_address
TON_API_KEY=your_toncenter_api_key

# ─── Workers ───
WITHDRAWAL_CONCURRENCY=10
BALANCE_SYNC_BATCH_SIZE=200

# ─── Metrics ───
METRICS_ENABLED=true
